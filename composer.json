{
    "name": "tu/disscusion-card-theme",
    "description": "A Flarum extension that provides a card theme for discussions",
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "tu",
            "email": "hzhwb040719@163.com"
        }
    ],
    "require": {
        "flarum/core": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Tu\\DisscusionCardTheme\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Disscusion Card Theme",
            "icon": {
                "name": "fas fa-th-large",
                "color": "#fff",
                "backgroundColor": "#007bff"
            }
        },
        "flarum-cli": {
            "modules": {
                "admin": true,
                "forum": true,
                "js": true,
                "css": true,
                "locale": true,
                "git-hooks": true,
                "github-actions": true
            }
        }
    }
}
